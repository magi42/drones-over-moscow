{
  "name": "drones-over-moscow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "clean": "rm -rf dist release drones-over-moscow.tar.gz",
    "release:dir": "rm -rf release && mkdir -p release/drones-over-moscow && cp -r index.html dist release/drones-over-moscow/",
    "release": "npm run clean && npm run build && npm run release:dir",
    "package": "npm run release && tar -C release -czf drones-over-moscow.tar.gz drones-over-moscow"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.0",
    "@react-three/rapier": "^2.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.181.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-react": "^5.1.0",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.0.6"
  }
}
